//PROJECTION COMPUTE SHADER
//1.Create moving bounding sphere to filter relevant pixels
//2.for each pixel, create the line in clip space and its 2 intersecting points
//3.to simulate the Rotation, rotate the pixel for initial time and create n lines splitting the rotational+linear movement
//4. check for intersections with each tri in the mesh, each intersection is counted 



// Each #kernel tells which function to compile; you can have many kernels
#pragma kernel ProjectionMap

// Create a RenderTexture with enableRandomWrite flag and set it
// with cs.SetTexture

RWTexture2D<float4> _Pixels;
RWStructuredBuffer<float3> _CollisionMesh;
int _TriangleCount;
float3 _Position;
float3 _Velocity;
float _Rotation;
float _Time;
float _Radius;
uint _Resolution;
// Returns float2(t_start, t_end)
// If no intersection, returns a negative value or a specific 'fail' signal
float2 RayCircleIntersection(float3 pixelOffset)
{
    if(length(_Velocity)==0) return float2(-1.0, -1.0);
    float3 direction = normalize(_Velocity);
    float radius = _Radius * dot(_Velocity, _Velocity);
    // Quadratic coefficients: at^2 + bt + c = 0
    float b = -dot(pixelOffset, direction);
    float c = dot(pixelOffset, pixelOffset) - radius * radius;
    float discriminant = (b * b) - c;
    
    if (discriminant < 0.0) return float2(-1.0, -1.0);
    float sqrtDisc = sqrt(discriminant);
    
    float t0 = (-b - sqrtDisc);
    float t1 = (-b + sqrtDisc);
    
    return float2(t0, t1);
}
float2 GetPositionAtTime(float3 pixel, float t)
{
    float2 offset = (float2)_Position - (float2) _Velocity * t;
    float rotation = _Rotation * t;
    float s = sin(rotation);
    float c = cos(rotation);
    
    // Construct the rotation matrix
    float2x2 rot = float2x2(c, -s, s, c);
    
    // Multiply the matrix by the point
    return mul(rot, offset);
}


// Segment P = P0 + t*(P1 - P0),  t ∈ [0,1]
// Segment Q = Q0 + u*(Q1 - Q0),  u ∈ [0,1]
// Returns t where the segments intersect, or -1 if no intersection.
float SegmentSegmentIntersectT(float3 P0, float3 P1,
                               float3 Q0, float3 Q1)
{
    float3 u = P1 - P0;
    float3 v = Q1 - Q0;
    float3 w0 = P0 - Q0;

    float a = dot(u, u); // always >= 0
    float b = dot(u, v);
    float c = dot(v, v); // always >= 0
    float d = dot(u, w0);
    float e = dot(v, w0);

    float denom = a * c - b * b;

    // If denom is near zero, segments are parallel
    if (abs(denom) < 1e-8)
        return -1.0;

    float t = (b * e - c * d) / denom;
    float uParam = (a * e - b * d) / denom;

    // Check if intersection lies within both segments
    if (t < 0.0 || t > 1.0)
        return -1.0;
    if (uParam < 0.0 || uParam > 1.0)
        return -1.0;

    // Compute the closest points
    float3 Pc = P0 + t * u;
    float3 Qc = Q0 + uParam * v;

    // Check if the segments actually touch
    if (length(Pc - Qc) > 1e-6)
        return -1.0;

    return t; // intersection point along segment P
}
//V0, V1, V2 are the vertices of the triangle  
// Returns float2(t_start, t_end) for where the segment crosses the triangle otherwise -1 if no intersection
float2 LineTriangleIntersect(float3 LineStart, float3 LineEnd,
                             float3 V0, float3 V1, float3 V2)
{
    float3 dir = LineEnd - LineStart;
    float t1 = SegmentSegmentIntersectT(LineStart, LineEnd, V0, V1);
    float t2 = SegmentSegmentIntersectT(LineStart, LineEnd, V0, V2);
    float t3 = SegmentSegmentIntersectT(LineStart, LineEnd, V1, V2);
    //No intersection
    if (t1 < 0 && t2 < 0 && t3 < 0)
        return float2(-1, -1);
    //Partial
    if(t1<0&&t2<0 || t1<0&&t3<0 || t2<0&&t3<0)
        if(t1>0) return float2(t1, t1);
        else if(t2>0) return float2(t2, t2);
        else return float2(t3, t3);
    //Full crossing
    if (t1 < 0) 
        return float2(min(t2, t3), max(t2, t3));
    else if (t2 < 0) 
        return float2(min(t1, t3), max(t1, t3));
    else
        return float2(min(t2, t1), max(t2, t1));
}
float4 Intersection(float3 lineStart, float3 lineEnd)
{
    float segmentLength = length(lineEnd - lineStart);
    float overlap = 0;
    float time = 0;
    for (int i = 0; i < _TriangleCount; i++)
    {
        float3 v0 = _CollisionMesh[i * 3];
        float3 v1 = _CollisionMesh[i * 3 + 1];
        float3 v2 = _CollisionMesh[i * 3 + 2];
        float2 timeRange = LineTriangleIntersect(lineStart, lineEnd, v0, v1, v2);
        if (timeRange.x > 0)
        {
            float delta = timeRange.y - timeRange.x;
            overlap += delta;
            time += (timeRange.x + timeRange.y) / 2;
        }
        
    }
    if (overlap == 0)return float4(0,0,0,0);
    return float4((1 - time) / overlap, 0, time / overlap, overlap);
}
float4 GetPixelColour(float start, float end)
{
    float overlap = end - start;
    float time = (start+end) / 2;
    return float4((1 - time) / overlap, 0, time / overlap, overlap);
}
[numthreads(8,8,1)]
void ProjectionMap (uint3 id : SV_DispatchThreadID)
{
    float3 offset = id - _Resolution / (float)2;
    float3 pixelPos = _Position+offset;
    float2 intersectionTimes = RayCircleIntersection(offset);
    if (intersectionTimes.y < 0)
    {
        _Pixels[id.xy] = float4(0, 1, 0, 0.3);
        return;
    }
    float startTime = intersectionTimes.x;
    float endTime = intersectionTimes.y;
    _Pixels[id.xy] = float4(1, 1, 1, 1);//GetPixelColour(startTime, endTime);
    //float2 lineStart = GetPositionAtTime(pixelPos, startTime);
    //float2 lineEnd = GetPositionAtTime(pixelPos, endTime);
    //_Pixels[id.xy] = Intersection(float3(lineStart, 0), float3(lineEnd, 0));

}
